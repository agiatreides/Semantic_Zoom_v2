  "voice_anchors": [
    {
      "nodeId": "5-0",
      "snippet": "So here's the thing about having a superintelligent AI living in your head: it ruins your ability to argue.",
      "note": "Direct-address confession in the first sentence establishes the wry, self-aware register the whole story runs on."
    },
    {
      "nodeId": "5-19",
      "snippet": "just my daughter, sixteen years old, trying to figure out how to be a person in a world that thinks it's solved everything.",
      "note": "Stripped syntax and the mid-sentence pivot from data to wonder carry the story's emotional center in a single breath."
    },
    {
      "nodeId": "5-23",
      "snippet": "Optimization is not wisdom. Data is not judgment. And an assistant, no matter how intelligent, is still an assistant.",
      "note": "Chip's clipped aphoristic cadence deliberately mimics earned wisdom while insisting on his own limit — the story's thesis in his voice."
    }
  ],
