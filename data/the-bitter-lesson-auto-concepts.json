    "secondary": "essay",
    "reasoning": "Sutton states a clear thesis about computation vs. human-knowledge approaches and argues it with historical evidence across chess, Go, speech, and vision."
  },
  "thematic_thrust": "Seventy years of AI history prove that computation-scaling methods—search and learning—consistently and decisively beat human-knowledge-engineered approaches.",
  "characters": {
    "Rich Sutton": "author; RL researcher who coined the bitter lesson",
    "Kasparov": "world chess champion defeated by deep search in 1997",
    "DARPA": "US defense agency that sponsored 1970s speech recognition contest",
    "Moore's law": "empirical principle of exponentially falling computation cost per unit",
    "HMMs": "Hidden Markov Models; statistical speech method that beat knowledge-based rivals",
    "SIFT features": "hand-engineered image descriptors superseded by deep learning",
    "Deep learning": "neural network paradigm scaling computation over domain knowledge"
  },
  "voice_anchors": [
    {
      "nodeId": "4-9",
      "snippet": "The eventual success is tinged with bitterness, and often incompletely digested, because it is success over a favored, human-centric approach",
      "note": "Names the psychological register the whole essay inhabits: field-level self-critique accepting an unwelcome verdict."
    },
    {
      "nodeId": "4-7",
      "snippet": "a colossal waste of researcher's time, when, through Moore's law, massive computation became available and a means was found to put it to good use",
      "note": "Shifts from analytic to bluntly polemical; the essay's sharpest direct condemnation of the field's pattern."
    },
    {
      "nodeId": "4-11",
      "snippet": "We want AI agents that can discover like we can, not which contain what we have discovered",
      "note": "Aspirational and aphoristic; the only prescriptive flourish, pivoting the essay from critique to constructive vision."
    }
  ],
